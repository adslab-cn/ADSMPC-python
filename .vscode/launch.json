{
    "version": "0.2.0",
    "configurations": [
        {
        "name": "Run GLUE Private",
        "type": "debugpy",
        "request": "launch",
        "program": "${workspaceFolder}/SHAFT/examples/text-classification/run_glue_private.py",
        "console": "integratedTerminal",
        "args": [
            "--model_name_or_path", "andeskyl/bert-base-cased-qnli",
            "--task_name", "qnli",
            "--len_data", "128",
            "--num_data", "12",
            "--max_length", "128",
            "--comp",
            "--per_device_eval_batch_size", "1",
            "--output_dir", "eval_private/qnli/"
        ],
        "justMyCode": true 
        },
        {
            "name": "Run Test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/Test.py",
            "console": "integratedTerminal",
            "args": [
            ],
            "justMyCode": true 
        },
        {
            "name": "Plan Keys: BERT-base",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/SHAFT/crypten/utils/generate_model_plan.py",
            "console": "integratedTerminal",
            "args": [
                "--model_name_or_path",
                "bert-base-cased",
                "--num_inferences",
                "1",
                "--batch_size",
                "1",
                "--seq_length",
                "128"
            ],
            "justMyCode": true ,
            "env": {
                // --- 关键添加 ---
                // 告诉 Python 解释器，在项目的根目录 (ADSMPC-python) 下去查找模块
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        }
    ]
}